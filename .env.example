TTLOCK_CLIENT_ID=your_ttlock_client_id
TTLOCK_CLIENT_SECRET=your_ttlock_client_secret
TTLOCK_USERNAME=your_ttlock_email
# Masukkan password yang sudah di-MD5 (lowercase hex). Contoh: go run ./cmd/md5gen -password 'password' atau echo -n 'password' | go run ./cmd/md5gen
TTLOCK_PASSWORD_MD5=md5_of_your_password
# Optional: override the API base URL if you use a regional TTLock endpoint
# TTLOCK_BASE_URL=https://euapi.ttlock.com
